<Window x:Class="SensorDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sensor Monitoring Dashboard" Height="450" Width="800">

	<Grid Background="#F0F0F0">
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

			<Border x:Name="voltageBorder" Width="200" Height="150" Margin="10" Background="Gray" CornerRadius="10">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Voltage Sensor" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
					<TextBlock x:Name="txtVoltage" Text="Waiting..." FontSize="24" Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
					<TextBlock x:Name="txtTemp" Text="0 °C" Foreground="White" HorizontalAlignment="Center"/>
				</StackPanel>
			</Border>

			<Border x:Name="gasBorder" Width="200" Height="150" Margin="10" Background="Gray" CornerRadius="10">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Gas Sensor" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
					<TextBlock x:Name="txtPpm" Text="Waiting..." FontSize="24" Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
				</StackPanel>
			</Border>

			<Border x:Name="lightBorder" Width="200" Height="150" Margin="10" Background="Gray" CornerRadius="10">
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Light Sensor" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
					<TextBlock x:Name="txtLux" Text="Waiting..." FontSize="24" Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
				</StackPanel>
			</Border>

		</StackPanel>
	</Grid>
</Window>